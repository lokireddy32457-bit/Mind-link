# =========================================
# Mind Link — Environment Variables
# =========================================
# Copy this file to .env for local development.
# On Render, set these in the dashboard or render.yaml.

# Flask secret key (auto-generated on Render)
SECRET_KEY=change-me-to-a-random-string

# Flask environment
FLASK_ENV=development

# ─── Email / SMTP Settings ─────────────────────────────────────────────────────
# Used to send appointment notifications to patients.
# Gmail recommended — create an App Password at:
# https://myaccount.google.com/apppasswords  (requires 2-Step Verification)

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-clinic-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_NAME=Mind Link Psychiatry Clinic
FROM_EMAIL=your-clinic-email@gmail.com
